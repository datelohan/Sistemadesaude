
# ─── App ────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database (MySQL no Docker) ──────────────────────────
DATABASE_URL="mysql://smeds:smeds@mysql:3306/smeds_dev"
DATABASE_TEST_URL="mysql://smeds:smeds@mysql:3306/smeds_test"
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=smeds_dev
MYSQL_USER=smeds
MYSQL_PASSWORD=smeds

# ─── JWT ─────────────────────────────────────────────────
JWT_SECRET=troque-por-segredo-forte-de-32-chars-minimo
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Storage (MinIO em dev / S3 em prod) ─────────────────
AWS_ENDPOINT=http://localhost:9000
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=minio123
S3_BUCKET_NAME=smeds

# ─── Queue (ElasticMQ em dev / SQS em prod) ─────────────
SQS_ENDPOINT=http://localhost:9324
SQS_QUEUE_URL=http://localhost:9324/000000000000/smeds-emails
AWS_ACCOUNT_ID=000000000000

# ─── Email (Mailhog em dev / SES em prod) ───────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@smeds.com.br

# ─── MinIO (apenas dev) ──────────────────────────────────
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123

# ─── CORS ────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173
